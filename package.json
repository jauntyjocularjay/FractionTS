{
    "name": "fractionts",
    "version": "1.0.0",
    "description": "Immutable rational number type for TypeScript and JavaScript. Supports exact arithmetic via static methods, with optional implicit coercion to floating-point for use in standard numeric expressions.",
    "main": "./dist/Fraction.mjs",
    "exports": {
        ".": {
            "import": "./dist/Fraction.mjs",
            "types": "./dist/Fraction.d.ts"
        }
    },
    "scripts": {
        "dev": "npm i",
        "build": "tsc",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
        "test:cjs": "npm run build && node test/cjs-compat.cjs",
        "test:all": "clear && npm test && npm run test:cjs"
    },
    "type": "module",
    "jest": {
        "extensionsToTreatAsEsm": [
            ".ts",
            ".mts"
        ],
        "moduleNameMapper": {
            "^(.*)\\.mjs$": "$1.mts"
        },
        "moduleFileExtensions": [
            "js",
            "mjs",
            "cjs",
            "ts",
            "mts",
            "json",
            "node"
        ],
        "transform": {
            "^.+\\.m?[jt]s$": "babel-jest"
        },
        "coverageDirectory": "./docs"
    },
    "keywords": [],
    "author": "jauntyjocularjay",
    "license": "MIT",
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-typescript": "^7.28.5",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.0",
        "babel-jest": "^30.3.0",
        "jest": "^30.3.0",
        "typescript": "^6.0.2"
    }
}
