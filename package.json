{
    "name": "fractionts",
    "version": "1.0.0",
    "description": "Immutable rational number type for TypeScript and JavaScript. Supports exact arithmetic via static methods, with optional implicit coercion to floating-point for use in standard numeric expressions.",
    "main": "./dist/Fraction.mjs",
    "exports": {
        ".": {
            "import": "./dist/Fraction.mjs",
            "types": "./dist/Fraction.d.ts"
        }
    },
    "scripts": {
        "dev": "npm i && git submodule update --init --recursive",
        "build": "tsc",
        "test": "clear && node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
        "test:cjs": "npm run build && node test/cjs-compat.cjs",
        "test:all": "npm test && npm run test:cjs",
        "eslint": "eslint Fraction.mts Errors.mts"
    },
    "type": "module",
    "jest": {
        "extensionsToTreatAsEsm": [
            ".ts",
            ".mts"
        ],
        "moduleNameMapper": {
            "^(.*)\\.mjs$": "$1.mts"
        },
        "moduleFileExtensions": [
            "js",
            "mjs",
            "cjs",
            "ts",
            "mts",
            "json",
            "node"
        ],
        "transform": {
            "^.+\\.m?[jt]s$": "babel-jest"
        },
        "coverageDirectory": "./docs"
    },
    "keywords": [],
    "author": "jauntyjocularjay",
    "license": "MIT",
    "dependencies": {
        "@types/node": "^18.0.6"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-typescript": "^7.28.5",
        "@types/jest": "^30.0.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "eslint": "^10.1.0",
        "jest": "^30.3.0",
        "typescript": "^6.0.2"
    }
}